# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./storage/main_backend.db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-12345678
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Model Server Configuration
MODEL_SERVER_URL=http://localhost:8001
MODEL_SERVER_USERNAME=backend_service
MODEL_SERVER_PASSWORD=SecurePassword123!

# RTSP Configuration (comma-separated RTSP URLs - leave empty if none)
RTSP_STREAMS=rtsp://admin:admin123@192.168.128.10:554/avstream/channel=1/stream=0.sdp
MOTION_DETECTION_THRESHOLD=500
KEYFRAME_INTERVAL=30
PROCESS_EVERY_N_FRAMES=5

# Storage
PHOTOS_DIR=./storage/photos
FRAMES_CACHE_DIR=./storage/frames_cache

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
